# Build artifacts
dist/
build/
*.spec
__pycache__/
*.pyc

# Generated game data — produced locally by srextract from YOUR OWN game copy.
# Nothing extracted from the game is committed; the repo ships only code + tooling.
recipes.json
icons.json
# Game art (Creepy Jar's copyrighted textures) — regenerate locally with srextract.
# The folder itself is kept (icons/.gitkeep) so build.bat works; PNGs are not redistributed.
icons/*.png

# Intermediate / derived data dumps
recipes_dump.json
recipes_final.json
recipes_final2.json
recipes_catalog_backup.json
icons_src.json

# Local runtime config (also stored in %LOCALAPPDATA%)
config.json

# Dumper debug output
diag.txt

# icon-extractor build outputs (CUE4Parse is cloned by build.bat)
tools/icon-extractor/CUE4Parse/
tools/icon-extractor/bin/
tools/icon-extractor/obj/
tools/icon-extractor/publish/
*.usmap
